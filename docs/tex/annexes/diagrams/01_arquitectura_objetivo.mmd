flowchart LR
    U[Usuario Operativo]:::actor --> WEB[Cliente Web - Navegador]:::client
    ADMUSR[Administrador]:::actor --> WEB

    subgraph APP[Contenedor Aplicacion - Plataforma Shiny]
      UI[Interfaz bs4Dash]:::service
      CTRL[Controlador Reactivo]:::service
      AUTH[Servicio de Autenticacion]:::service
      FIND[Servicio de Busqueda y Filtros]:::service
      DOS[Servicio de Expedientes RRHH]:::service
      EXP[Servicio de Exportacion XLS]:::service
      AUD[Servicio de Auditoria]:::service
    end

    subgraph DATA[Contenedor de Datos]
      UDB[(usuarios.csv)]:::db
      ADB[(datos_archivo.csv)]:::db
      PDB[(rrhh_personas.csv)]:::db
      FDB[(rrhh_archivos.csv)]:::db
      LDB[(audit_log.csv)]:::db
    end

    subgraph OPS[Servicios Operacionales]
      DEP[Servicio de Despliegue]:::ops
      BCK[Backups Programados]:::ops
      MON[Monitoreo y Alertas]:::ops
    end

    WEB --> UI
    UI --> CTRL

    CTRL --> AUTH
    CTRL --> FIND
    CTRL --> DOS
    CTRL --> EXP
    CTRL --> AUD

    AUTH --> UDB
    FIND --> ADB
    DOS --> PDB
    DOS --> FDB
    AUD --> LDB

    DEP -. hospeda .-> UI
    BCK -. protege .-> UDB
    BCK -. protege .-> ADB
    BCK -. protege .-> PDB
    BCK -. protege .-> FDB
    MON -. observa .-> CTRL

